# ============================================================
#  VARIABLES D'ENVIRONNEMENT — copier en .env et remplir
#  NE JAMAIS commiter le fichier .env sur GitHub
# ============================================================

# ----------------------------------------------------------
# Django — OBLIGATOIRE en production
# ----------------------------------------------------------

# Clé secrète unique (générer avec : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
SECRET_KEY=remplacer-par-une-vraie-cle-secrete

# False en production, True en développement local
DEBUG=False

# Domaine(s) autorisés (séparés par des virgules, sans espaces)
# Exemple : mon-app.onrender.com,www.monsite.fr
ALLOWED_HOSTS=mon-app.onrender.com

# ----------------------------------------------------------
# Base de données — Neon.tech PostgreSQL
# Récupérer dans : Neon Dashboard > Projet > Connection String
# Format : postgresql://user:password@host/dbname?sslmode=require
# ----------------------------------------------------------
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ----------------------------------------------------------
# Stockage fichiers media — Cloudflare R2
# True en production, False en développement local
# ----------------------------------------------------------
USE_S3=True

# Tableau de bord Cloudflare > R2 > Manage API Tokens
R2_ACCESS_KEY_ID=votre-access-key-id
R2_SECRET_ACCESS_KEY=votre-secret-access-key

# Nom du bucket créé dans Cloudflare R2
R2_BUCKET_NAME=nom-du-bucket

# URL d'API R2 : https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# Récupérer ACCOUNT_ID dans Cloudflare Dashboard (barre latérale droite)
R2_ENDPOINT_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com

# URL publique du bucket R2 (activer "Public Access" dans R2 pour obtenir cette URL)
# Format R2.dev : https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
# Ou domaine custom Cloudflare : https://media.monsite.fr
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# ----------------------------------------------------------
# IA — Gemini (optionnel, si fonctionnalité utilisée)
# ----------------------------------------------------------
GEMINI_API_KEY=votre-cle-gemini
# GEMINI_API_KEY_2=cle-de-rotation-2
# GEMINI_API_KEY_3=cle-de-rotation-3

# ElevenLabs (optionnel)
# ELEVENLABS_API_KEY=votre-cle-elevenlabs
